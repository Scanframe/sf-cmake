		},
		{
			"name": "gw-coverage",
			"hidden": false,
			"displayName": "Coverage GW",
			"description": "Coverage config Windows GW compiler on Linux.",
			"inherits": [
				".qt",
				".cfg-win"
			],
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": {
					"type": "STRING",
					"value": "Coverage"
				}
			}
		},
		{
			"name": "gw-debug",
