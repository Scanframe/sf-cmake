			],
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": {
					"type": "STRING",
					"value": "Release"
				},
				"SF_COMPILER": {
					"type": "STRING",
					"value": "mingw"
				}
			},
			"vendor": {
				"jetbrains.com/clion": {
					"toolchain": "MinGW"
				}
			}
		},
		{
			"name": "msvc-debug",
			"hidden": false,
			"displayName": "Debug MSVC",
			"description": "Debug config for MSVC compiler on Windows.",
			"inherits": [
				".qt",
				".tc-msvc-2022",
				".cfg-w64"
			],
			"cacheVariables": {
				"SF_COMPILER": {
					"type": "STRING",
					"value": "msvc"
				}
			},
			"vendor": {
				"jetbrains.com/clion": {
					"toolchain": "MSVC"
				}
			}
		},
		{
			"name": "msvc-release",
			"hidden": false,
			"displayName": "Release MSVC",
			"description": "Release config for MSVC compiler on Windows.",
			"inherits": [
				".qt",
				".tc-msvc-2022",
				".cfg-w64"
			],
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": {
					"type": "STRING",
					"value": "Release"
				},
				"SF_COMPILER": {
					"type": "STRING",
					"value": "msvc"
				}
			},
			"vendor": {
