{
	"version": 6,
	"cmakeMinimumRequired": {
		"major": 3,
		"minor": 25,
		"patch": 0
	},
	"configurePresets": [
		{
			"name": ".cfg",
			"hidden": true,
			"generator": "Ninja",
			"binaryDir": "${sourceDir}/cmake-build$penv{SF_BIN_DIR_SUFFIX}/${presetName}",
			"environment": {
				"SF_LIBRARY_DIR": "$env{SF_EXECUTABLE_DIR}/lib"
			},
			"cacheVariables": {
				"CMAKE_RUNTIME_OUTPUT_DIRECTORY": {
					"type": "STRING",
					"value": "$env{SF_EXECUTABLE_DIR}"
				},
				"CMAKE_LIBRARY_OUTPUT_DIRECTORY": {
					"type": "STRING",
					"value": "$env{SF_LIBRARY_DIR}"
				},
				"CMAKE_COLOR_DIAGNOSTICS": {
					"type": "BOOL",
					"value": "ON"
				},
				"CMAKE_MESSAGE_LOG_LEVEL": {
					"type": "STRING",
					"value": "VERBOSE"
				},
				"CMAKE_VERBOSE_MAKEFILE": {
					"type": "BOOL",
					"value": "OFF"
				},
				"CMAKE_BUILD_TYPE": {
					"type": "STRING",
					"value": "Debug"
				},
				"SF_BUILD_QT": {
					"type": "BOOL",
					"value": "OFF"
				},
				"SF_BUILD_TESTING": {
					"type": "BOOL",
					"value": "OFF"
				},
				"SF_COMPILER": {
					"type": "STRING",
					"value": ""
				},
				"SF_COVERAGE_ONLY_TARGETS": {
					"type": "STRING",
					"value": ""
				}
			}
		},
		{
			"name": ".lnx-only",
			"hidden": true,
			"condition": {
				"type": "equals",
				"lhs": "${hostSystemName}",
				"rhs": "Linux"
			}
		},
		{
			"name": ".w64-only",
			"hidden": true,
			"condition": {
				"type": "equals",
				"lhs": "${hostSystemName}",
				"rhs": "Windows"
			}
		},
		{
			"name": ".tc-msvc",
			"description": "Toolchain for generic MSVC",
			"hidden": true,
			"environment": {
				"MSVC_ROOT": "$penv{MSVC_ROOT}",
				"VCToolsVersion": "14.44.35207",
				"WindowsSDKVersion": "10.0.26100.0",
				"VSCMD_ARG_HOST_ARCH": "x64",
				"VSCMD_ARG_TGT_ARCH": "x64",
				"VCToolsInstallDir": "$env{MSVC_ROOT}\\VC\\Tools\\MSVC\\$env{VCToolsVersion}",
				"WindowsSdkBinPath": "$env{MSVC_ROOT}\\Windows Kits\\10\\bin",
				"LIB": "$env{MSVC_ROOT}\\VC\\Tools\\MSVC\\$env{VCToolsVersion}\\lib\\$env{VSCMD_ARG_TGT_ARCH};$env{MSVC_ROOT}\\Windows Kits\\10\\Lib\\$env{WindowsSDKVersion}\\ucrt\\$env{VSCMD_ARG_TGT_ARCH};$env{MSVC_ROOT}\\Windows Kits\\10\\Lib\\$env{WindowsSDKVersion}\\um\\$env{VSCMD_ARG_TGT_ARCH}",
				"INCLUDE": "$env{MSVC_ROOT}\\VC\\Tools\\MSVC\\$env{VCToolsVersion}\\include;$env{MSVC_ROOT}\\Windows Kits\\10\\Include\\$env{WindowsSDKVersion}\\ucrt;$env{MSVC_ROOT}\\Windows Kits\\10\\Include\\$env{WindowsSDKVersion}\\shared;$env{MSVC_ROOT}\\Windows Kits\\10\\Include\\$env{WindowsSDKVersion}\\um;$env{MSVC_ROOT}\\Windows Kits\\10\\Include\\$env{WindowsSDKVersion}\\winrt;$env{MSVC_ROOT}\\Windows Kits\\10\\Include\\$env{WindowsSDKVersion}\\cppwinrt",
				"PATH": "$env{SF_LIBRARY_DIR};$env{MSVC_ROOT}\\VC\\Tools\\MSVC\\$env{VCToolsVersion}\\bin\\Host$env{VSCMD_ARG_TGT_ARCH}\\$env{VSCMD_ARG_TGT_ARCH};$env{MSVC_ROOT}\\Windows Kits\\10\\bin\\$env{WindowsSDKVersion}\\$env{VSCMD_ARG_TGT_ARCH};$env{MSVC_ROOT}\\Windows Kits\\10\\bin\\$env{WindowsSDKVersion}\\$env{VSCMD_ARG_TGT_ARCH}\\ucrt;$penv{PATH}"
			},
			"cacheVariables": {
				"SF_COMPILER": {
					"type": "STRING",
					"value": "msvc"
				}
			}
		},
		{
			"name": ".tc-msvc-2022",
			"description": "Toolchain for MSVC 2022",
			"hidden": true,
			"inherits": [
				".tc-msvc"
			],
			"environment": {
				"VCToolsVersion": "14.44.35207",
				"WindowsSDKVersion": "10.0.26100.0"
			}
		},
		{
			"name": ".tc-msvc-2026",
			"description": "Toolchain for MSVC 2026",
			"hidden": true,
			"inherits": [
				".tc-msvc"
			],
			"environment": {
				"VCToolsVersion": "14.50.35717",
				"WindowsSDKVersion": "10.0.26100.0"
			}
		},
		{
			"name": ".qt",
			"hidden": true,
			"cacheVariables": {
				"SF_BUILD_QT": {
					"type": "BOOL",
					"value": "ON"
				}
			}
		},
		{
			"name": ".cfg-lnx",
			"inherits": [
				".lnx-only",
				".cfg"
			],
			"hidden": true,
			"displayName": "Debug Linux Template",
			"description": "Debug config Linux template.",
			"environment": {
				"SF_EXECUTABLE_DIR": "${sourceDir}/bin/lnx64$penv{SF_EXEC_DIR_SUFFIX}",
				"LD_LIBRARY_PATH": "$env{SF_LIBRARY_DIR}:$penv{LD_LIBRARY_PATH}"
			},
			"cacheVariables": {
				"SF_BUILD_TESTING": {
					"type": "BOOL",
					"value": "ON"
				},
				"SF_COMPILER": {
					"type": "STRING",
					"value": "gnu"
				}
			},
			"vendor": {
				"compiler": "gnu"
			}
		},
		{
			"name": ".cfg-lnx-arm",
			"inherits": [
				".cfg-lnx"
			],
			"hidden": true,
			"displayName": "Debug Linux Template",
			"description": "Debug config Linux template.",
			"cacheVariables": {
				"SF_COMPILER": {
					"type": "STRING",
					"value": "ga"
				}
			},
			"vendor": {
				"compiler": "ga"
			}
		},
		{
			"name": ".cfg-win",
			"inherits": [
				".lnx-only",
				".cfg"
			],
			"hidden": true,
			"displayName": "Debug Windows Template",
			"description": "Debug config Windows template.",
			"environment": {
				"SF_EXECUTABLE_DIR": "${sourceDir}/bin/win64$penv{SF_EXEC_DIR_SUFFIX}"
			},
			"cacheVariables": {
				"SF_BUILD_TESTING": {
					"type": "BOOL",
					"value": "ON"
				},
				"SF_COMPILER": {
					"type": "STRING",
					"value": "gw"
				}
			},
			"vendor": {
				"compiler": "gw"
			}
		},
		{
			"name": ".cfg-w64",
			"inherits": [
				".w64-only",
				".cfg"
			],
			"hidden": true,
			"displayName": "Debug Windows Template",
			"description": "Debug config Windows template.",
			"environment": {
				"SF_EXECUTABLE_DIR": "${sourceDir}/bin/win64$penv{SF_EXEC_DIR_SUFFIX}",
				"PATH": "$env{SF_LIBRARY_DIR};$penv{PATH}"
			},
			"cacheVariables": {
				"SF_BUILD_TESTING": {
					"type": "BOOL",
					"value": "ON"
				},
				"SF_COMPILER": {
					"type": "STRING",
					"value": "mingw"
				}
			}
		},
		{
			"name": "gnu-debug",
			"hidden": false,
			"displayName": "Debug GNU",
			"description": "Debug config GNU compiler on Linux.",
			"inherits": [
				".qt",
				".cfg-lnx"
			],
			"cacheVariables": {
			}
		},
		{
			"name": "ga-debug",
			"hidden": false,
			"displayName": "Debug GA",
			"description": "Debug config GNU Arm compiler on Linux.",
			"inherits": [
				".qt",
				".cfg-lnx-arm"
			],
			"cacheVariables": {
			}
		},
		{
			"name": "gnu-coverage",
			"hidden": false,
			"displayName": "Coverage GNU",
