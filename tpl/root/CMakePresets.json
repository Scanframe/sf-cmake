				".qt",
				".cfg-lnx-arm"
			],
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": {
					"type": "STRING",
					"value": "Release"
				}
			}
		},
		{
			"name": "gw-release",
			"hidden": false,
			"displayName": "Release GW",
			"description": "Release config for Windows GW compiler on Linux.",
			"inherits": [
				".qt",
				".cfg-win"
			],
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": {
					"type": "STRING",
					"value": "Release"
				}
			}
		},
		{
			"name": "mingw-debug",
			"hidden": false,
			"displayName": "Debug MinGW",
			"description": "Debug config for MinGW compiler on Windows.",
			"inherits": [
				".qt",
				".cfg-w64"
			],
			"cacheVariables": {
				"SF_COMPILER": {
					"type": "STRING",
					"value": "mingw"
				}
			},
			"vendor": {
				"jetbrains.com/clion": {
					"toolchain": "MinGW"
				}
			}
		},
		{
			"name": "mingw-release",
			"hidden": false,
			"displayName": "Release MinGW",
			"description": "Release config for MinGW compiler on Windows.",
			"inherits": [
				".qt",
