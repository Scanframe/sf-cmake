{
	"version": 6,
	"configurePresets": [
		{
			"name": "gw-user",
			"hidden": false,
			"displayName": "User GW",
			"description": "Debug config for Windows GW compiler on Linux.",
			"inherits": [
				".lnx-only",
				".cfg-win"
			],
			"binaryDir": "${sourceDir}/cmake-build/gw-user",
			"environment": {
				"QT_VER_DIR": "$penv{HOME}/lib/QtWin/6.6.3"
			}
		},
		{
			"name": "gnu-user",
			"hidden": false,
			"displayName": "User GNU",
			"description": "Debug config for Linux GNU compiler.",
			"inherits": [
				".lnx-only",
				".cfg"
			],
			"binaryDir": "${sourceDir}/cmake-build/gnu-user"
		}
	],
	"buildPresets": [
		{
			"name": "gw-user",
			"hidden": false,
			"inherits": [
				".lnx-only",
				".build"
			],
			"displayName": "User GW",
			"description": "User debug build preset GW compiler.",
			"configurePreset": "gw-user",
			"targets": [
				"t_devops-shared-test"
			]
		},
		{
			"name": "gnu-user",
			"hidden": false,
			"inherits": [
				".lnx-only",
				".build"
			],
			"displayName": "User GNU",
			"description": "User debug build preset GNU compiler.",
			"configurePreset": "gnu-user",
			"targets": [
				"t_devops-shared-test"
			]
		}
	],
	"testPresets": [
		{
			"name": "gw-user",
			"hidden": false,
			"displayName": "User GW",
			"description": "User test debug Windows GW compiler on Linux.",
			"inherits": [
				".lnx-only",
				".test"
			],
			"configurePreset": "gw-user"
		},
		{
			"name": "gnu-user",
			"hidden": false,
			"displayName": "User GNU",
			"description": "User test debug Linux.",
			"inherits": [
				".lnx-only",
				".test"
			],
			"configurePreset": "gnu-user"
		}
	],
	"packagePresets": [
	],
	"workflowPresets": [
		{
			"name": "gw-user",
			"displayName": "User GW",
			"description": "User build & test only.",
			"steps": [
				{
					"type": "configure",
					"name": "gw-user"
				},
				{
					"type": "build",
					"name": "gw-user"
				},
				{
					"type": "test",
					"name": "gw-user"
				}
			],
			"vendor": {
				"target_os": "GNU/Linux"
			}
		},
		{
			"name": "gnu-user",
			"displayName": "User GNU",
			"description": "User build & test only.",
			"steps": [
				{
					"type": "configure",
					"name": "gnu-user"
				},
				{
					"type": "build",
					"name": "gnu-user"
				},
				{
					"type": "test",
					"name": "gnu-user"
				}
			],
			"vendor": {
				"target_os": "GNU/Linux"
			}
		}
	]
}