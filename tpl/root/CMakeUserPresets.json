{
	"version": 6,
	"configurePresets": [
		{
			"name": "gw-user",
			"hidden": false,
			"displayName": "GW Dbg Compiler",
			"description": "GW Debug config for cross Windows GW compiler on Linux.",
			"inherits": [
				".lnx-only",
				".cfg-win"
			],
			"binaryDir": "${sourceDir}/cmake-build/gw-user",
			"environment": {
				"QT_VER_DIR": "$penv{HOME}/lib/QtWin/6.6.3"
			}
		},
		{
			"name": "gnu-user",
			"hidden": false,
			"displayName": "GNU Dbg Compiler",
			"description": "GNU Debug config for Linux.",
			"inherits": [
				".lnx-only",
				".cfg-lnx"
			],
			"binaryDir": "${sourceDir}/cmake-build/gnu-user"
		}
	],
	"buildPresets": [
		{
			"name": "gw-user",
			"hidden": false,
			"inherits": [
				".lnx-only",
				".build"
			],
			"displayName": "GW User Dbg",
			"description": "GW User debug build preset.",
			"configurePreset": "gw-user",
			"targets": [
				"t_devops-shared-test"
			]
		},
		{
			"name": "gnu-user",
			"hidden": false,
			"inherits": [
				".lnx-only",
				".build"
			],
			"displayName": "GNU User Dbg",
			"description": "GNU User debug build preset.",
			"configurePreset": "gnu-user",
			"targets": [
				"t_devops-shared-test"
			]
		}
	],
	"testPresets": [
		{
			"name": "gw-user",
			"hidden": false,
			"displayName": "GW User Dbg",
			"description": "GW user test debug Windows cross compiler on Linux.",
			"inherits": [
				".lnx-only",
				".test"
			],
			"configurePreset": "gw-user"
		},
		{
			"name": "gnu-user",
			"hidden": false,
			"displayName": "GNU User Dbg",
			"description": "GNU user test debug Linux.",
			"inherits": [
				".lnx-only",
				".test"
			],
			"configurePreset": "gnu-user"
		}
	],
	"packagePresets": [
	],
	"workflowPresets": [
		{
			"name": "gw-user",
			"displayName": "GW User Build & Test",
			"description": "GW User build & test only.",
			"steps": [
				{
					"type": "configure",
					"name": "gw-user"
				},
				{
					"type": "build",
					"name": "gw-user"
				},
				{
					"type": "test",
					"name": "gw-user"
				}
			],
			"vendor": {
				"target_os": "GNU/Linux"
			}
		},
		{
			"name": "gnu-user",
			"displayName": "GNU User Build & Test",
			"description": "GNU User build & test only.",
			"steps": [
				{
					"type": "configure",
					"name": "gnu-user"
				},
				{
					"type": "build",
					"name": "gnu-user"
				},
				{
					"type": "test",
					"name": "gnu-user"
				}
			],
			"vendor": {
				"target_os": "GNU/Linux"
			}
		}
	]
}