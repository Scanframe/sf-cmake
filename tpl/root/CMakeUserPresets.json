{
	"version": 6,
	"configurePresets": [
		{
			"name": "gw-user",
			"hidden": false,
			"displayName": "User GW",
			"description": "Debug config for Windows GW compiler on Linux.",
			"inherits": [
				".lnx-only",
				".cfg-win"
			],
			"cacheVariables": {
				"SF_COMPILER": {
					"type": "STRING",
					"value": "gw"
				},
				"SF_BUILD_TESTING": {
					"type": "BOOL",
					"value": "ON"
				}
			},
			"environment": {
				"--QT_VER_DIR": "$penv{HOME}/lib/qt/w64-x86_64/6.8.1"
			},
			"vendor": {
				"jetbrains.com/clion": {
					"toolchain": "MinGW"
				}
			}
		},
		{
			"name": "msvc-debug-local",
			"hidden": false,
			"displayName": "Debug Local MSVC",
			"description": "Debug local config for MSVC compiler.",
			"inherits": [
				"msvc-debug"
			],
			"binaryDir": "$env{TEMP}/cmake-build$penv{SF_BIN_DIR_SUFFIX}/${presetName}",
			"vendor": {
				"jetbrains.com/clion": {
					"toolchain": "MSVC"
				}
			}
		}
	],
	"buildPresets": [
		{
			"name": "gw-user",
			"hidden": false,
			"inherits": [
				".lnx-only",
				".build"
			],
			"displayName": "User GW",
			"description": "User debug build preset GW compiler.",
			"configurePreset": "gw-user",
			"targets": [
				"t_devops-shared-test-catch",
				"t_devops-shared-test-google"
			]
		},
		{
			"name": "msvc-debug-local",
			"displayName": "Debug Local MSVC",
			"description": "Debug local config for MSVC compiler.",
			"inherits": [
				"msvc-debug"
			],
			"configurePreset": "msvc-debug-local",
			"targets": [
				"t_devops-shared-test-catch",
				"t_devops-shared-test-google"
			]
		}
	],
	"testPresets": [
		{
			"name": "gw-user",
			"hidden": false,
			"displayName": "User GW",
			"description": "User test debug Windows GW compiler on Linux.",
			"inherits": [
				".lnx-only",
				".test"
			],
			"configurePreset": "gw-user"
		},
		{
			"name": "msvc-debug-local",
			"displayName": "Debug Local MSVC",
			"description": "Debug local config for MSVC compiler.",
			"inherits": [
				"msvc-debug"
			],
			"configurePreset": "msvc-debug-local"
		}
	],
	"packagePresets": [
	],
	"workflowPresets": [
		{
			"name": "gw-user",
			"displayName": "User GW",
			"description": "User build & test only.",
			"steps": [
				{
					"type": "configure",
					"name": "gw-user"
				},
				{
					"type": "build",
					"name": "gw-user"
				},
				{
					"type": "test",
					"name": "gw-user"
				}
			],
			"vendor": {
				"target_os": "GNU/Linux"
			}
		},
		{
			"name": "msvc-debug-local",
			"displayName": "Debug Local MSVC",
			"description": "Debug local config for MSVC compiler.",
			"steps": [
				{
					"type": "configure",
					"name": "msvc-debug-local"
				},
				{
					"type": "build",
					"name": "msvc-debug-local"
				},
				{
					"type": "test",
					"name": "msvc-debug-local"
				}
			],
			"vendor": {
				"target_os": "Cygwin"
			}
		}
	]
}